# JanVedha Voice Agent - Environment Configuration

ENVIRONMENT=development

# Database connections (Make sure this points to the same DB as main JanVedha backend)
MONGODB_URI=mongodb://localhost:27017/civicai

# API Keys
SARVAM_API_KEY=your_sarvam_api_key
GEMINI_API_KEY=your_gemini_api_key

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_number

# Google Cloud Fallback (Optional, for STT/TTS fallbacks)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/key.json

# Voice Configuration Defaults
TELEPHONY_PROVIDER=demo  # demo | twilio | exotel
SARVAM_STT_MODEL=saaras:v3
SARVAM_TTS_MODEL=bulbul:v1
SARVAM_TRANSLATE_MODEL=mayura:v1
SARVAM_CONFIDENCE_THRESHOLD=0.70
VOICE_SILENCE_TIMEOUT_MS=1500
VOICE_SESSION_TTL_SECONDS=600
VOICE_MAX_CALL_DURATION_SECONDS=300


